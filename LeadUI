<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lead Prospector — Import, Filter, Export</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<style>
  :root{
    --navy:#003366; --navy-700:#012b54; --navy-900:#011d3a;
    --ink:#0f1a2a; --slate:#5b6b80; --line:#e2e8f0; --line-2:#eef2f7;
    --bg:#f5f7fa; --card:#ffffff; --sky:#2BA1EA; --gold:#FCCF4C;
    --green:#16794d; --green-bg:#e6f4ec; --amber:#9a6700; --amber-bg:#fdf3d6;
    --grey:#475569; --grey-bg:#eef1f5; --red:#b42318; --red-bg:#fdecea;
    --radius:12px; --shadow:0 1px 2px rgba(2,12,27,.06),0 8px 24px rgba(2,12,27,.05);
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  body{
    font-family:"DM Sans",system-ui,-apple-system,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    background:var(--bg); color:var(--ink); -webkit-font-smoothing:antialiased;
    font-size:14px; line-height:1.45;
  }
  h1,h2,h3{font-family:"PolySans","DM Sans",system-ui,sans-serif;margin:0;letter-spacing:-.01em}
  button{font-family:inherit;cursor:pointer}
  .mono{font-family:ui-monospace,"SFMono-Regular",Menlo,Consolas,monospace}

  /* ---- Top bar ---- */
  header.topbar{
    background:linear-gradient(180deg,var(--navy) 0%,var(--navy-700) 100%);
    color:#fff; padding:14px 22px; display:flex; align-items:center; gap:16px;
    position:sticky; top:0; z-index:40;
  }
  .brandmark{
    width:34px;height:34px;border-radius:9px;background:var(--sky);
    display:grid;place-items:center;flex:0 0 auto;font-weight:700;font-size:15px;color:#fff;
    box-shadow:inset 0 0 0 1px rgba(255,255,255,.18);
  }
  .brand h1{font-size:17px;font-weight:600;line-height:1.1}
  .brand .sub{font-size:11px;color:#9fc2e6;letter-spacing:.06em;text-transform:uppercase;margin-top:1px}
  .topbar .spacer{flex:1}
  .live{display:flex;align-items:center;gap:7px;font-size:12px;color:#c9def4;
    background:rgba(255,255,255,.08);padding:6px 12px;border-radius:999px}
  .dot{width:8px;height:8px;border-radius:50%;background:#3ad07f;box-shadow:0 0 0 3px rgba(58,208,127,.25)}

  /* ---- Layout ---- */
  .wrap{max-width:1280px;margin:0 auto;padding:22px}
  .toolbar{display:flex;flex-wrap:wrap;gap:10px;align-items:center;margin-bottom:18px}
  .btn{
    border:1px solid var(--line);background:var(--card);color:var(--navy);
    padding:10px 16px;border-radius:9px;font-weight:600;font-size:13.5px;
    display:inline-flex;align-items:center;gap:8px;transition:.15s;
  }
  .btn:hover{border-color:var(--sky);background:#f3f9fe}
  .btn.primary{background:var(--navy);color:#fff;border-color:var(--navy)}
  .btn.primary:hover{background:var(--navy-700)}
  .btn.gold{background:var(--gold);color:var(--navy-900);border-color:var(--gold);font-weight:700}
  .btn.gold:hover{filter:brightness(.96)}
  .btn.ghost{background:transparent}
  .btn.danger{color:var(--red);border-color:#f3c9c4}
  .btn.danger:hover{background:var(--red-bg)}
  .btn:disabled{opacity:.45;cursor:not-allowed}
  .btn svg{width:16px;height:16px}

  /* ---- Stat cards ---- */
  .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px}
  .stat{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);
    padding:16px 18px;box-shadow:var(--shadow)}
  .stat .label{font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:var(--slate);font-weight:600}
  .stat .num{font-family:"PolySans","DM Sans",sans-serif;font-size:30px;font-weight:700;margin:4px 0 2px;line-height:1}
  .stat .num.accent{color:var(--navy)}
  .stat .num.sky{color:var(--sky)}
  .stat .hint{font-size:11.5px;color:var(--slate)}

  /* ---- Filter panel ---- */
  .panel{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);
    box-shadow:var(--shadow);margin-bottom:18px}
  .panel-pad{padding:16px 18px}
  .chiprow{display:flex;flex-wrap:wrap;gap:8px;align-items:center}
  .chiprow .lab{font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:var(--slate);
    font-weight:700;margin-right:4px}
  .chip{
    border:1px solid var(--line);background:#fff;border-radius:999px;padding:7px 14px;
    font-size:13px;font-weight:600;color:var(--grey);display:inline-flex;align-items:center;gap:7px;transition:.12s;
  }
  .chip:hover{border-color:var(--sky)}
  .chip.on{background:var(--navy);color:#fff;border-color:var(--navy)}
  .chip .ct{font-size:11px;background:rgba(0,0,0,.08);border-radius:999px;padding:1px 7px;color:inherit}
  .chip.on .ct{background:rgba(255,255,255,.22)}

  .filters-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;border-top:1px solid var(--line-2);
    padding:16px 18px}
  .field label{display:block;font-size:11px;letter-spacing:.05em;text-transform:uppercase;
    color:var(--slate);font-weight:700;margin-bottom:5px}
  .field input,.field select{width:100%;padding:9px 11px;border:1px solid var(--line);border-radius:8px;
    font-size:13.5px;font-family:inherit;background:#fff;color:var(--ink)}
  .field input:focus,.field select:focus{outline:none;border-color:var(--sky);box-shadow:0 0 0 3px rgba(43,161,234,.12)}

  /* ---- Selection bar ---- */
  .selbar{display:flex;align-items:center;gap:14px;padding:12px 18px;border-top:1px solid var(--line-2);
    flex-wrap:wrap}
  .selbar .count{font-size:13.5px;color:var(--slate)}
  .selbar .count b{color:var(--navy);font-size:15px}
  .selbar .spacer{flex:1}
  .linkbtn{background:none;border:none;color:var(--sky);font-weight:600;font-size:13px;padding:4px 6px}
  .linkbtn:hover{text-decoration:underline}

  /* ---- Table ---- */
  .tablecard{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);
    box-shadow:var(--shadow);overflow:hidden}
  .tablehead{display:flex;justify-content:space-between;align-items:center;padding:13px 18px;
    border-bottom:1px solid var(--line-2)}
  .tablehead .t{font-weight:600;font-size:14px}
  .tablehead .s{font-size:12px;color:var(--slate)}
  .tablescroll{max-height:560px;overflow:auto}
  table{border-collapse:collapse;width:100%;font-size:13px}
  thead th{position:sticky;top:0;background:#f8fafc;z-index:2;text-align:left;
    padding:10px 12px;font-size:11px;letter-spacing:.04em;text-transform:uppercase;color:var(--slate);
    font-weight:700;border-bottom:1px solid var(--line);white-space:nowrap;cursor:pointer;user-select:none}
  thead th .arrow{color:#b5c0cd;font-size:10px;margin-left:3px}
  thead th.nosort{cursor:default}
  tbody td{padding:10px 12px;border-bottom:1px solid var(--line-2);vertical-align:top}
  tbody tr:hover{background:#f7fafd}
  tbody tr.unchecked{opacity:.5}
  .biz{font-weight:600;color:var(--navy)}
  .muted{color:var(--slate)}
  .stpill{font-size:11px;font-weight:700;padding:3px 9px;border-radius:999px;display:inline-block;white-space:nowrap}
  .st-new{background:var(--green-bg);color:var(--green)}
  .st-contacted{background:var(--amber-bg);color:var(--amber)}
  .st-closed{background:var(--grey-bg);color:var(--grey)}
  .st-qualified{background:#e7eefb;color:#1f4eb5}
  .certtag{font-size:10px;font-weight:700;padding:2px 7px;border-radius:5px;text-transform:uppercase;letter-spacing:.03em}
  .c-acc{background:#e7eefb;color:#1f4eb5}
  .c-com{background:#fdf3d6;color:#9a6700}
  .c-ppm{background:#fdecea;color:#b42318}
  .c-wav{background:#ede9fe;color:#6d28d9}
  .c-gen{background:#eef1f5;color:#475569}
  .chk{width:16px;height:16px;accent-color:var(--navy);cursor:pointer}
  .rowmenu{background:none;border:none;color:var(--slate);font-size:18px;line-height:1;padding:2px 8px;border-radius:6px}
  .rowmenu:hover{background:var(--line-2);color:var(--red)}

  /* ---- Empty state ---- */
  .empty{padding:64px 24px;text-align:center;color:var(--slate)}
  .empty .ic{width:54px;height:54px;border-radius:14px;background:var(--grey-bg);display:grid;
    place-items:center;margin:0 auto 14px}
  .empty h3{color:var(--ink);font-size:16px;margin-bottom:6px}
  .empty p{max-width:420px;margin:0 auto 18px;font-size:13.5px}

  /* ---- Modal ---- */
  .overlay{position:fixed;inset:0;background:rgba(8,20,38,.55);display:none;align-items:flex-start;
    justify-content:center;z-index:60;padding:40px 16px;overflow:auto}
  .overlay.show{display:flex}
  .modal{background:#fff;border-radius:14px;max-width:680px;width:100%;box-shadow:0 20px 60px rgba(2,12,27,.3);
    overflow:hidden}
  .modal .mhead{background:var(--navy);color:#fff;padding:16px 20px;display:flex;justify-content:space-between;align-items:center}
  .modal .mhead h2{font-size:17px;font-weight:600}
  .modal .mhead .x{background:none;border:none;color:#fff;font-size:22px;line-height:1;cursor:pointer;opacity:.85}
  .modal .mhead .x:hover{opacity:1}
  .modal .mbody{padding:20px}
  .modal p.lead{color:var(--slate);font-size:13.5px;margin:0 0 16px}
  .modal p.lead b{color:var(--ink)}
  .drop{border:2px dashed var(--line);border-radius:12px;padding:38px 20px;text-align:center;
    transition:.15s;background:#fbfdff}
  .drop.over{border-color:var(--sky);background:#eef8ff}
  .drop .cl{color:var(--sky);font-weight:700}
  .drop .ac{font-size:12px;color:var(--slate);margin-top:6px}
  .drop svg{width:42px;height:42px;color:#9fb3c8;margin-bottom:8px}

  /* ---- Mapping table ---- */
  .maptbl{width:100%;border-collapse:collapse;margin-top:6px}
  .maptbl th{text-align:left;font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:var(--slate);
    padding:8px;border-bottom:1px solid var(--line)}
  .maptbl td{padding:7px 8px;border-bottom:1px solid var(--line-2);font-size:13px;vertical-align:middle}
  .maptbl select{width:100%;padding:6px 8px;border:1px solid var(--line);border-radius:7px;font-size:12.5px;font-family:inherit}
  .maptbl .src{font-weight:600}
  .pill-auto{font-size:10px;font-weight:700;color:var(--green);background:var(--green-bg);padding:2px 7px;border-radius:5px;margin-left:6px}
  .pill-miss{font-size:10px;font-weight:700;color:var(--amber);background:var(--amber-bg);padding:2px 7px;border-radius:5px;margin-left:6px}
  .mfoot{display:flex;justify-content:flex-end;gap:10px;padding:16px 20px;border-top:1px solid var(--line-2);background:#fafcfe}

  /* ---- Toast ---- */
  #toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%) translateY(20px);
    background:var(--navy-900);color:#fff;padding:12px 20px;border-radius:10px;font-size:13.5px;font-weight:500;
    opacity:0;transition:.25s;z-index:80;box-shadow:0 8px 24px rgba(0,0,0,.25);pointer-events:none;max-width:90vw}
  #toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
  #toast.err{background:#7a1109}

  .hide{display:none!important}
  @media(max-width:880px){
    .stats{grid-template-columns:repeat(2,1fr)}
    .filters-grid{grid-template-columns:repeat(2,1fr)}
    .wrap{padding:14px}
  }
  @media(max-width:560px){
    .filters-grid{grid-template-columns:1fr}
    .stat .num{font-size:24px}
    table{font-size:12px}
  }
</style>
</head>
<body>
<header class="topbar">
  <div class="brandmark">LP</div>
  <div class="brand">
    <h1>Lead Prospector</h1>
    <div class="sub">Import · Filter · Export</div>
  </div>
  <div class="spacer"></div>
  <div class="live"><span class="dot"></span> Local &amp; private</div>
</header>

<div class="wrap">

  <!-- Toolbar -->
  <div class="toolbar">
    <button class="btn primary" id="importBtn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 16V4m0 0l-4 4m4-4l4 4M4 20h16"/></svg>
      Import leads
    </button>
    <button class="btn gold" id="exportBtn" disabled>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v12m0 0l4-4m-4 4l-4-4M4 4h16"/></svg>
      Export to template (<span id="exportCt">0</span>)
    </button>
    <div style="flex:1"></div>
    <button class="btn danger ghost" id="clearBtn">Clear all</button>
  </div>

  <!-- Stats -->
  <div class="stats">
    <div class="stat"><div class="label">Total leads</div><div class="num accent" id="stTotal">0</div><div class="hint">in workspace</div></div>
    <div class="stat"><div class="label">Matching filters</div><div class="num sky" id="stShown">0</div><div class="hint">visible below</div></div>
    <div class="stat"><div class="label">Selected for export</div><div class="num" id="stSel">0</div><div class="hint">ticked rows</div></div>
    <div class="stat"><div class="label">Excluded</div><div class="num" id="stExcl">0</div><div class="hint">filtered out or unticked</div></div>
  </div>

  <!-- Filter panel -->
  <div class="panel">
    <div class="panel-pad">
      <div class="chiprow" id="certChips">
        <span class="lab">Certificate</span>
        <!-- chips injected -->
      </div>
    </div>
    <div class="filters-grid">
      <div class="field">
        <label>Search (name, official, city, NPI, phone)</label>
        <input type="text" id="fSearch" placeholder="Type to filter…" autocomplete="off">
      </div>
      <div class="field">
        <label>State</label>
        <select id="fState"><option value="">All states</option></select>
      </div>
      <div class="field">
        <label>Status</label>
        <select id="fStatus"><option value="">All statuses</option></select>
      </div>
      <div class="field">
        <label>Source</label>
        <select id="fSource"><option value="">All sources</option></select>
      </div>
    </div>
    <div class="selbar">
      <div class="count"><b id="selCount">0</b> of <span id="selOf">0</span> matching leads selected for export</div>
      <button class="linkbtn" id="selAll">Select all matching</button>
      <button class="linkbtn" id="selNone">Deselect all</button>
      <div class="spacer"></div>
      <button class="linkbtn" id="resetFilters">Reset filters</button>
    </div>
  </div>

  <!-- Table -->
  <div class="tablecard">
    <div class="tablehead">
      <div class="t">Leads</div>
      <div class="s" id="tableMeta">No leads yet</div>
    </div>
    <div class="tablescroll" id="tableScroll">
      <div class="empty" id="emptyState">
        <div class="ic">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#9fb3c8" stroke-width="2"><path d="M4 4h16v4H4zM4 12h10v8H4zM18 12h2v8h-2z"/></svg>
        </div>
        <h3>No leads loaded</h3>
        <p>Import an NPPES, CLIA, Apollo, or ZoomInfo export (.xlsx, .xls, or .csv). Columns are auto-detected; you can remap anything that doesn't match.</p>
        <button class="btn primary" id="importBtn2">Import leads</button>
      </div>
      <table id="leadTable" class="hide">
        <thead><tr id="theadRow"></tr></thead>
        <tbody id="tbody"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- Import modal -->
<div class="overlay" id="importModal">
  <div class="modal">
    <div class="mhead"><h2>Import leads</h2><button class="x" data-close>&times;</button></div>
    <div class="mbody">
      <p class="lead">Drop an <b>NPPES NPI</b>, <b>CLIA labs</b>, <b>Apollo</b>, or <b>ZoomInfo</b> export below. New records are added to your workspace; nothing is removed. CLIA rows with a <b>Waiver</b> certificate are kept and tagged (not suppressed) so you can filter them yourself.</p>
      <div class="drop" id="dropZone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 16V4m0 0L8 8m4-4l4 4M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2"/></svg>
        <div><span class="cl">Click to choose a file</span> or drag &amp; drop here</div>
        <div class="ac">Accepts .xlsx, .xls, .csv</div>
      </div>
      <input type="file" id="fileInput" accept=".xlsx,.xls,.csv" class="hide">
    </div>
  </div>
</div>

<!-- Mapping modal -->
<div class="overlay" id="mapModal">
  <div class="modal">
    <div class="mhead"><h2>Confirm column mapping</h2><button class="x" data-close>&times;</button></div>
    <div class="mbody">
      <p class="lead">Auto-detected mappings are marked <span class="pill-auto">auto</span>. Anything we couldn't match is <span class="pill-miss">unmapped</span> — set it or leave it as <b>Ignore</b>. <span id="mapFileMeta"></span></p>
      <table class="maptbl">
        <thead><tr><th style="width:42%">Your column</th><th style="width:14%">Sample</th><th>Maps to</th></tr></thead>
        <tbody id="mapBody"></tbody>
      </table>
    </div>
    <div class="mfoot">
      <button class="btn ghost" data-close>Cancel</button>
      <button class="btn primary" id="confirmImport">Import <span id="mapRowCt"></span> leads</button>
    </div>
  </div>
</div>

<div id="toast"></div>

<script>
/* ============================================================
   EMBEDDED MASTER TEMPLATE (base64) — export base, preserves
   README / TABLES / dropdowns / slicers.
   ============================================================ */
const TEMPLATE_B64 = "